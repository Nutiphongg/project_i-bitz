generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model Return {
  return_id        Int         @id @default(autoincrement())
  booking_item_id  Int         @unique
  condition_status String      @db.VarChar(20)
  fine_amount      Float       @default(0) @db.Real
  return_date      DateTime    @default(now()) @db.Timestamptz(6)
  bookingitem      bookingitem @relation(fields: [booking_item_id], references: [booking_item_id], onDelete: NoAction, onUpdate: NoAction)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model booking {
  booking_id   Int           @id @default(autoincrement())
  member_id    Int
  booking_date DateTime      @default(now()) @db.Timestamptz(6)
  total_amount Float?        @db.Real
  status       String        @default("pending") @db.VarChar(20)
  member       member        @relation(fields: [member_id], references: [member_id], onDelete: NoAction, onUpdate: NoAction)
  bookingitem  bookingitem[]
  payment      payment[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model bookingitem {
  booking_item_id Int          @id @default(autoincrement())
  booking_id      Int
  item_id         Int
  start_date      DateTime     @db.Timestamptz(6)
  end_date        DateTime     @db.Timestamptz(6)
  Return          Return?
  booking         booking      @relation(fields: [booking_id], references: [booking_id], onDelete: Cascade, onUpdate: NoAction)
  productitems    productitems @relation(fields: [item_id], references: [item_id], onDelete: NoAction, onUpdate: NoAction)
}

model categories {
  category_id   Int       @id @default(autoincrement())
  category_name String    @unique @db.VarChar(50)
  product       product[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model member {
  member_id           Int              @id @default(autoincrement())
  membership_level_id Int
  username            String           @unique @db.VarChar(20)
  email               String           @unique @db.VarChar(255)
  password            String           @db.VarChar(255)
  status              String           @default("active") @db.VarChar(20)
  role                String           @default("user") @db.VarChar(20)
  booking             booking[]
  membership_level    membership_level @relation(fields: [membership_level_id], references: [level_id], onDelete: NoAction, onUpdate: NoAction)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model membership_level {
  level_id      Int      @id @default(autoincrement())
  level_name    String   @db.VarChar(20)
  discount_rate Float    @default(0) @db.Real
  member        member[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model payment {
  payment_id   Int      @id @default(autoincrement())
  booking_id   Int
  payment_type String   @db.VarChar(20)
  amount       Float    @db.Real
  payment_date DateTime @default(now()) @db.Timestamptz(6)
  booking      booking  @relation(fields: [booking_id], references: [booking_id], onDelete: NoAction, onUpdate: NoAction)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model product {
  product_id     Int            @id @default(autoincrement())
  product_name   String         @db.VarChar(50)
  category_id    Int
  price_day      Int
  deposit_amount Int            @default(0)
  categories     categories     @relation(fields: [category_id], references: [category_id], onDelete: NoAction, onUpdate: NoAction)
  productitems   productitems[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model productitems {
  item_id     Int           @id @default(autoincrement())
  product_id  Int
  status      String        @default("available") @db.VarChar(20)
  bookingitem bookingitem[]
  product     product       @relation(fields: [product_id], references: [product_id], onDelete: Cascade, onUpdate: NoAction)
}
